        "text_mLEnDe": {
          "type": "text",
          "settings": {
            "ttl": "<p>NOCTURA® - Wear the Night. Own<br/>the Room. We didn't make clothes for everyone.<br/><br/>We made them for you - the ones who show up differently, dress differently, and don't need a reason to stand out.</p>",
            "tff": "ft3",
            "fs": 25,
