      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "sstm",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Spacing top (mobile)",
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "ssbm",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Spacing bottom (mobile)",
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "hidem",
      "label": "Hide on mobile?",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hided",
      "label": "Hide on desktop?",
      "default": false
    }
  ], 
  "presets": [
    {
      "name": "Product Bundle",
      "category": "Products"
    }
  ]
}
{% endschema %}
